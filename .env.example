# Environment Configuration

# Real-time Polling Interval (milliseconds)
VITE_POLL_INTERVAL=5000

# App Configuration
VITE_APP_NAME=Popote
VITE_APP_URL=http://localhost:5173

# Web Push (VAPID) — for event reminders & notifications (issue #7).
# Generate a keypair with:  node scripts/generate-vapid-keys.mjs
# - VAPID_PUBLIC_KEY  (NOT secret): also set in void.json worker.vars; shipped
#   to clients so they can subscribe.
# - VAPID_SUBJECT     (NOT secret): a mailto: or https: contact URL.
# - VAPID_PRIVATE_KEY (SECRET): keep in .env.local locally; in production use
#   `void secret put VAPID_PRIVATE_KEY`. NEVER commit it.
VAPID_PUBLIC_KEY=
VAPID_SUBJECT=mailto:you@example.com
VAPID_PRIVATE_KEY=

# >>> void env: managed block — do not edit between markers <<<
# Run `void env example` to refresh.
# required
# enum: development | production
NODE_ENV=
VITE_APP_TITLE=
BETTER_AUTH_SECRET=

# with defaults
PORT=5173

# optional
DEBUG=
# >>> end void env <<<
