{
  "name": "popote",
  "main": ".svelte-kit/cloudflare/_worker.js",
  "compatibility_date": "2026-02-24",
  "compatibility_flags": ["nodejs_als", "nodejs_compat"],
  "assets": {
    "binding": "ASSETS",
    "directory": ".svelte-kit/cloudflare",
  },
  "vars": {
    "OTEL_EXPORTER_OTLP_ENDPOINT": "https://signoz.pri.vsantele.dev/http",
    "OTEL_SERVICE_NAME": "popote-server",
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "default",
      "database_id": "local",
    },
  ],
}
