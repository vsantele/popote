{
  "name": "Popote Backend Schema",
  "version": "1.0.0",
  "description": "PocketBase schema for Popote collaborative meal planning app",
  "collections": [
    {
      "name": "events",
      "type": "base",
      "system": false,
      "fields": [
        {
          "name": "name",
          "type": "text",
          "required": true,
          "description": "Event/party name (e.g., 'Barbecue chez Nico')",
          "validation": {
            "min": 1,
            "max": 200
          }
        },
        {
          "name": "date",
          "type": "date",
          "required": true,
          "description": "Event date and time"
        },
        {
          "name": "location",
          "type": "text",
          "required": false,
          "description": "Event location/address (optional)",
          "validation": {
            "max": 500
          }
        },
        {
          "name": "description",
          "type": "text",
          "required": false,
          "description": "Additional notes about the event (optional)",
          "validation": {
            "max": 2000
          }
        },
        {
          "name": "host_name",
          "type": "text",
          "required": true,
          "description": "Host's first name",
          "validation": {
            "min": 1,
            "max": 100
          }
        },
        {
          "name": "host_device_id",
          "type": "text",
          "required": true,
          "description": "Host device identifier for local auth",
          "validation": {
            "min": 1,
            "max": 100
          }
        },
        {
          "name": "share_code",
          "type": "text",
          "required": true,
          "unique": true,
          "description": "6-character unique code for sharing (auto-generated)",
          "validation": {
            "min": 6,
            "max": 6,
            "pattern": "^[A-Z0-9]{6}$"
          }
        }
      ],
      "indexes": [
        "share_code (unique)",
        "host_device_id",
        "date"
      ]
    },
    {
      "name": "participants",
      "type": "base",
      "system": false,
      "fields": [
        {
          "name": "event",
          "type": "relation",
          "required": true,
          "description": "Link to the event",
          "relation": {
            "collection": "events",
            "cascadeDelete": true,
            "maxSelect": 1
          }
        },
        {
          "name": "name",
          "type": "text",
          "required": true,
          "description": "Participant's first name",
          "validation": {
            "min": 1,
            "max": 100
          }
        },
        {
          "name": "device_id",
          "type": "text",
          "required": true,
          "description": "Device identifier for local data persistence",
          "validation": {
            "min": 1,
            "max": 100
          }
        },
        {
          "name": "is_host",
          "type": "bool",
          "required": false,
          "default": false,
          "description": "Whether this participant is the event host"
        }
      ],
      "indexes": [
        "event",
        "device_id"
      ]
    },
    {
      "name": "items",
      "type": "base",
      "system": false,
      "fields": [
        {
          "name": "event",
          "type": "relation",
          "required": true,
          "description": "Link to the event",
          "relation": {
            "collection": "events",
            "cascadeDelete": true,
            "maxSelect": 1
          }
        },
        {
          "name": "participant",
          "type": "relation",
          "required": true,
          "description": "Link to the participant bringing this item",
          "relation": {
            "collection": "participants",
            "cascadeDelete": true,
            "maxSelect": 1
          }
        },
        {
          "name": "name",
          "type": "text",
          "required": true,
          "description": "Item name (e.g., 'Tiramisu maison')",
          "validation": {
            "min": 1,
            "max": 200
          }
        },
        {
          "name": "category",
          "type": "select",
          "required": true,
          "description": "Item category",
          "options": [
            {
              "value": "apero",
              "label": "🥂 Apéro",
              "description": "Chips, dips, planches..."
            },
            {
              "value": "entree",
              "label": "🥗 Entrée",
              "description": "Salades, soupes..."
            },
            {
              "value": "plat",
              "label": "🍖 Plat",
              "description": "Plat principal, accompagnements..."
            },
            {
              "value": "dessert",
              "label": "🍰 Dessert",
              "description": "Gâteaux, fruits..."
            },
            {
              "value": "boissons",
              "label": "🍷 Boissons",
              "description": "Vin, bière, soft, eau..."
            },
            {
              "value": "jeux",
              "label": "🎲 Jeux / Activités",
              "description": "Jeux de société, musique..."
            },
            {
              "value": "autre",
              "label": "📦 Autre",
              "description": "Vaisselle jetable, serviettes, glacière..."
            }
          ]
        },
        {
          "name": "quantity",
          "type": "text",
          "required": false,
          "description": "Quantity/precision (e.g., 'pour 6 personnes', '2 bouteilles')",
          "validation": {
            "max": 100
          }
        }
      ],
      "indexes": [
        "event",
        "participant",
        "category"
      ]
    }
  ],
  "categories": {
    "description": "Fixed list of item categories (v1)",
    "values": [
      {
        "key": "apero",
        "label": "🥂 Apéro",
        "emoji": "🥂",
        "examples": ["Chips", "Dips", "Planches"]
      },
      {
        "key": "entree",
        "label": "🥗 Entrée",
        "emoji": "🥗",
        "examples": ["Salades", "Soupes"]
      },
      {
        "key": "plat",
        "label": "🍖 Plat",
        "emoji": "🍖",
        "examples": ["Plat principal", "Accompagnements"]
      },
      {
        "key": "dessert",
        "label": "🍰 Dessert",
        "emoji": "🍰",
        "examples": ["Gâteaux", "Fruits"]
      },
      {
        "key": "boissons",
        "label": "🍷 Boissons",
        "emoji": "🍷",
        "examples": ["Vin", "Bière", "Soft", "Eau"]
      },
      {
        "key": "jeux",
        "label": "🎲 Jeux / Activités",
        "emoji": "🎲",
        "examples": ["Jeux de société", "Musique"]
      },
      {
        "key": "autre",
        "label": "📦 Autre",
        "emoji": "📦",
        "examples": ["Vaisselle jetable", "Serviettes", "Glacière"]
      }
    ]
  }
}
